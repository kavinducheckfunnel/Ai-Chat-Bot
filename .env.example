# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
ALLOWED_HOSTS=app.checkfunnels.com

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_DB=checkfunnel_db
POSTGRES_USER=checkfunnel_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

# ── AWS Bedrock (DeepSeek AI + Titan Embeddings) ──────────────────────────────
FRIEND_AWS_ACCESS_KEY_ID=your_aws_access_key
FRIEND_AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-west-2

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=Checkfunnel <noreply@checkfunnels.com>

# ── Rate limits (optional overrides) ─────────────────────────────────────────
CHAT_RATE_LIMIT=30/min
CHAT_SESSION_RATE_LIMIT=10/min
